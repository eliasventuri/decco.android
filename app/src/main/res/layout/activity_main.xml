<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/decco_bg">

    <!-- WebView sits behind the splash -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Splash overlay – shown on top while WebView loads -->
    <LinearLayout
        android:id="@+id/splash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/decco_bg"
        android:elevation="10dp">

        <!-- Decco Logo -->
        <ImageView
            android:id="@+id/splash_logo"
            android:layout_width="180dp"
            android:layout_height="156dp"
            android:src="@drawable/ic_logo_anim"
            android:contentDescription="Decco logo" />

        <!-- Spacing -->
        <View
            android:layout_width="1dp"
            android:layout_height="48dp" />

        <!-- Loading spinner -->
        <ProgressBar
            android:id="@+id/splash_progress"
            style="?android:attr/progressBarStyle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="@color/decco_teal" />

        <!-- Loading text -->
        <TextView
            android:id="@+id/splash_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Cargando..."
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

</FrameLayout>
